{
  "name": "@agentplugins/store",
  "version": "0.6.0",
  "description": "Universal plugin store for AgentPlugins — install, link, and registry fs operations for ~/.agents/plugins/<name>/",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "agentplugins",
    "store",
    "install",
    "link",
    "plugin"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sigilco/agentplugins.git",
    "directory": "packages/store"
  },
  "homepage": "https://agentplugins.pages.dev/",
  "dependencies": {
    "@agentplugins/compile": "workspace:*",
    "@agentplugins/pipeline": "workspace:*",
    "@agentplugins/security": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
