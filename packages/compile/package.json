{
  "name": "@agentplugins/compile",
  "version": "0.5.0",
  "description": "Shared codegen kernel for AgentPlugins adapters. Secure emit helpers, sanitizers, lint, validation, hook-wrapper.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "agentplugins",
    "compile",
    "codegen",
    "kernel"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sigilco/agentplugins.git",
    "directory": "packages/compile"
  },
  "homepage": "https://agentplugins.pages.dev/",
  "dependencies": {
    "@agentplugins/contract": "workspace:*",
    "@agentplugins/pipeline": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
