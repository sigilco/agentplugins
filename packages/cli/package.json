{
  "name": "@agentbridge/cli",
  "version": "0.1.0",
  "description": "CLI for building AgentBridge plugins across multiple AI agent harnesses",
  "type": "module",
  "bin": {
    "agentbridge": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentbridge/core": "workspace:*",
    "@agentbridge/adapter-claude": "workspace:*",
    "@agentbridge/adapter-codex": "workspace:*",
    "@agentbridge/adapter-copilot": "workspace:*",
    "@agentbridge/adapter-gemini": "workspace:*",
    "@agentbridge/adapter-kimi": "workspace:*",
    "@agentbridge/adapter-opencode": "workspace:*",
    "@agentbridge/adapter-pimono": "workspace:*",
    "cac": "^6.7.14",
    "chalk": "^5.3.0",
    "jiti": "^1.21.6"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0"
  },
  "keywords": ["agentbridge", "cli", "ai", "plugin"],
  "license": "MIT"
}
