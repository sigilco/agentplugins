{
  "name": "@agentplugins/adapter-pimono",
  "version": "0.4.0",
  "description": "Pi Mono platform adapter for AgentPlugins — generates TypeScript-native extensions for the Pi agent runtime",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@agentplugins/core": "workspace:*",
    "@agentplugins/compile": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "agentplugins",
    "pi",
    "pimono",
    "agent",
    "extension",
    "adapter"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sigilco/agentplugins.git",
    "directory": "packages/adapter-pimono"
  },
  "homepage": "https://agentplugins.pages.dev/"
}
