{
  "name": "@agentplugins/adapter-pimono",
  "version": "0.6.0",
  "description": "Pi platform adapter for AgentPlugins. Generates TypeScript-native extensions for the Pi agent runtime",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format cjs,esm --dts",
    "dev": "tsdown src/index.ts --format cjs,esm --dts --watch",
    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@agentplugins/compile": "workspace:*",
    "@agentplugins/core": "workspace:*"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "agentplugins",
    "pi",
    "pimono",
    "agent",
    "extension",
    "adapter"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sigilco/agentplugins.git",
    "directory": "packages/adapter-pimono"
  },
  "homepage": "https://agentplugins.pages.dev/"
}