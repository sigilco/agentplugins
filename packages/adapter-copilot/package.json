{
  "name": "@agentplugin/adapter-copilot",
  "version": "0.1.0",
  "description": "GitHub Copilot CLI platform adapter for AgentPlugin — compiles AgentPlugin plugins into Copilot-compatible manifests, hooks, skills, and MCP configuration",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentplugin/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/espetro/agentplugin.git",
    "directory": "packages/adapter-copilot"
  },
  "keywords": [
    "agentplugin",
    "github-copilot",
    "copilot-cli",
    "plugin-adapter",
    "ai-agent",
    "mcp"
  ]
}
