{
  "name": "@agentplugins/schema",
  "version": "0.6.0",
  "description": "JSON Schema + TypeScript types + Ajv validators for the AgentPlugins manifest. The public contract for the ecosystem.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "files": [
    "dist",
    "schemas",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "agentplugins",
    "schema",
    "json-schema",
    "manifest",
    "ai",
    "plugin"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sigilco/agentplugins.git",
    "directory": "packages/schema"
  },
  "homepage": "https://agentplugins.pages.dev/",
  "dependencies": {
    "ajv": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}