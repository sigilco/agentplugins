{
  "name": "@agentplugins/contract",
  "version": "0.5.0",
  "description": "Single-source-of-truth manifest schema for AgentPlugins. Zod schema → TypeScript types → manifest.schema.json.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && node dist/generate-schema.js",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "files": [
    "dist",
    "manifest.schema.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["agentplugins", "schema", "contract", "zod", "manifest"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sigilco/agentplugins.git",
    "directory": "packages/contract"
  },
  "homepage": "https://agentplugins.pages.dev/",
  "dependencies": {
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.1.4"
  }
}
