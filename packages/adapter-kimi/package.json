{
  "name": "@agentplugins/adapter-kimi",
  "version": "0.6.0",
  "description": "AgentPlugins platform adapter for Kimi (Moonshot AI)",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.mts", "default": "./dist/index.mjs" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsdown src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@agentplugins/core": "workspace:*"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@agentplugins/core": "^0.6.0"
  },
  "keywords": [
    "agentplugins",
    "kimi",
    "moonshot",
    "plugin",
    "adapter"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sigilco/agentplugins.git",
    "directory": "packages/adapter-kimi"
  },
  "homepage": "https://agentplugins.pages.dev/"
}
