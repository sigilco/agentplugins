{
  "name": "@agentplugins/migrate",
  "version": "0.3.0",
  "description": "MCP server that wraps @agentplugins/ingest to let agents migrate community plugins conversationally.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agentplugins-migrate": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "start": "node dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "agentplugins",
    "mcp",
    "migrate",
    "compat",
    "model-context-protocol"
  ],
  "license": "MIT",
  "dependencies": {
    "@agentplugins/core": "workspace:*",
    "@agentplugins/ingest": "workspace:*",
    "@agentplugins/schema": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.1.4"
  }
}
