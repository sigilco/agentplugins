{
  "name": "@agentplugins/migrate",
  "version": "0.6.0",
  "description": "MCP server that wraps @agentplugins/ingest to let agents migrate community plugins conversationally.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agentplugins-migrate": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "start": "node dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "agentplugins",
    "mcp",
    "migrate",
    "compat",
    "model-context-protocol"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sigilco/agentplugins.git",
    "directory": "packages/migrate"
  },
  "homepage": "https://agentplugins.pages.dev/",
  "dependencies": {
    "@agentplugins/core": "workspace:*",
    "@agentplugins/ingest": "workspace:*",
    "@agentplugins/schema": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
